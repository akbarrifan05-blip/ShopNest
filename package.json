{
  "name": "shop-zone-ecom-mern",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "rifan"
  ],
  "license": "ISC",
  "author": "rifan",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "install": "npm install --prefix backend && npm install --prefix frontend",
    "postinstall": "npm run install",
    "dev:server": "npm --prefix backend run dev",
    "dev:client": "npm --prefix frontend start",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "node backend/index.js"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
